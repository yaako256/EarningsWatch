{
  "db_name": "PostgreSQL",
  "query": "\n      SELECT COUNT(*) as \"count!\" FROM logs\n      WHERE ($1::timestamptz IS NULL OR timestamp >= $1)\n        AND ($2::timestamptz IS NULL OR timestamp < $2)\n        AND ($3::text IS NULL OR level = $3)\n        AND ($4::log_process IS NULL OR process = $4)\n      ",
