{
  "db_name": "PostgreSQL",
  "query": "\n      SELECT h.id, h.group_id, h.fingerprint, h.sent_at, h.status as \"status: NotifyStatus\"\n      FROM notify_history h\n      JOIN notify_groups g ON g.id = h.group_id\n      WHERE g.user_id = $1 AND h.status = $2\n      ORDER BY h.sent_at DESC\n      LIMIT $3\n      ",
